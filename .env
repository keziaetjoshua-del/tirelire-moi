# .env.example

# ── Wallet Polygon ──────────────────────────────────────────────────────────
PRIVATE_KEY=0xef05832f368d4a45ab080f48de8437bf8cd069864a6edba89ba5a238df509700

# ── Polymarket ──────────────────────────────────────────────────────────────
POLYMARKET_API_URL=https://clob.polymarket.com

# ── APIs Météo ──────────────────────────────────────────────────────────────
# NOAA (USA, gratuit avec inscription) : https://www.ncdc.noaa.gov/cdo-web/token
NOAA_API_TOKEN=VOTRE_TOKEN_NOAA

# OpenWeatherMap (gratuit 1000 appels/j) : https://openweathermap.org/api
OPENWEATHER_API_KEY=VOTRE_CLE_OPENWEATHER

# Open-Meteo est gratuit sans clé, aucune config nécessaire

# ── Capital initial ─────────────────────────────────────────────────────────
INITIAL_BALANCE=170.0

# ── Paramètres bot ──────────────────────────────────────────────────────────
SCAN_INTERVAL=900        # 15 minutes
EV_THRESHOLD=0.10        # EV minimum 10%
DAILY_LOSS_LIMIT=0.03    # Bouclier 3%
MIN_BINS=5
MAX_BINS=10

# ── Dossier données persistantes ────────────────────────────────────────────
DATA_DIR=/app/data